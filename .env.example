# ═══════════════════════════════════════════════════
#  SKYY – Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# Flask
SECRET_KEY=your-256-bit-secret-key-here-change-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///skyy_todo.db
# DATABASE_URL=postgresql://user:password@localhost:5432/skyy_todo

# Security
SESSION_COOKIE_SECURE=False       # Set True in production (HTTPS)
REMEMBER_COOKIE_SECURE=False      # Set True in production (HTTPS)
CSP_REPORT_URI=                   # CSP violation report endpoint

# Rate Limiting (use Redis for production)
RATE_LIMIT_STORAGE=memory://
# RATE_LIMIT_STORAGE=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/skyy.log

# Email (for password reset – future feature)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password